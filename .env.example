# API Keys - Configure at least one LLM provider
# Default LLM when UI/API uses "auto": auto | claude | openai | kimi | minimax | ollama
LLM_PROVIDER=auto

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Kimi / Moonshot (OpenAI-compatible)
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.ai/v1

# MiniMax (OpenAI-compatible)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Ollama Cloud (https://ollama.com) — create API key at https://ollama.com/settings/keys
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b-cloud
# Default Ollama model when none is selected in the UI. Cloud models are listed
# dynamically at /api/llm/models — pick any available model in the web UI.
OLLAMA_API_KEY=

# Local Ollama fallback (uncomment if running Ollama on your machine instead)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_API_KEY=

# TTS Provider: auto | openai | elevenlabs
TTS_PROVIDER=auto

# OpenAI TTS
TTS_MODEL=tts-1
VOICE=alloy

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# Frame Critic (visual QA loop)
# ENABLE_FRAME_CRITIC=true
# CRITIC_MIN_SCORE=8        # 0-10; default 8 for high-quality output
# CRITIC_MAX_RETRIES=2

# Scene assembly
# SCENE_TRANSITION_DURATION=0.3   # seconds of fade in/out between scenes; 0 = hard cuts

# Supabase (optional — enables cloud persistence for jobs across restarts)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key
